# PostgreSQL connection string
# Supports: postgresql://, postgresql+asyncpg://, postgres://
# SSL is enabled automatically when sslmode=require is present or the host
# is not localhost/127.0.0.1 (e.g. Supabase, Neon, Railway).
#
# Local:    postgresql+asyncpg://postgres:postgres@localhost:5432/myproject
# Supabase: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres?sslmode=require
# Neon:     postgresql+asyncpg://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/myproject

# Redis connection string
# Supports: redis://, rediss:// (TLS), redis+ssl://
#
# Local:   redis://localhost:6379
# Upstash: rediss://:<password>@<host>:6380
REDIS_URL=redis://localhost:6379

# JWT signing secret — generate with: openssl rand -hex 64
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Initial admin account created on first run
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin1234

# S3-compatible object storage (optional — leave blank to disable uploads)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
